        self.list_area.pack(side="left", fill="both", expand=True)

        self.info_box = tk.Frame(split_box, bg="#252526", width=300, padx=20, pady=15)
        self.info_box.pack(side="right", fill="both")
        self.info_box.pack_propagate(False)

