class GML_App:
    def __init__(self, win):
        self.win = win
        self.win.title("GML - Gorilla Mod Libary")
        self.win.geometry("950x580")
        self.win.configure(bg=NIGHT_BG)

        # store the checkbutton states
        self.checks = {name: tk.BooleanVar(value=False) for name in my_mod_list}
        self.pre_checks = {name: tk.BooleanVar(value=False) for name in my_presets}
        self.active_tab = tk.StringVar(value="Core")
        
        # default steam path usually
        self.game_dir = tk.StringVar(value=r"C:\Program Files (x86)\Steam\steamapps\common\Gorilla Tag")

        # UI frames
        self.left_side = tk.Frame(win, bg=SIDE_BAR, width=160)
        self.left_side.pack(side="left", fill="y")
        self.left_side.pack_propagate(False)

        self.bottom_bar = tk.Frame(win, bg=SIDE_BAR, height=65)
        self.bottom_bar.pack(side="bottom", fill="x")

        self.main_view = tk.Frame(win, bg=NIGHT_BG)
        self.main_view.pack(side="right", fill="both", expand=True)

        # Title
        tk.Label(self.left_side, text="GML", bg=SIDE_BAR, fg=BLUE_HL, font=("Segoe UI", 20, "bold")).pack(pady=20)
        
        # Build sidebar buttons
        self.nav_btns = {}
        for t in TAB_NAMES:
            b = tk.Button(self.left_side, text=t, bg=SIDE_BAR, fg=GRAY_T, relief="flat", anchor="w", padx=20, 
