        top_row = tk.Frame(self.main_view, bg=NIGHT_BG, padx=10, pady=10)
        top_row.pack(fill="x")
        tk.Entry(top_row, textvariable=self.game_dir, bg="#3c3c3c", fg="white", relief="flat", font=("Segoe UI", 9)).pack(side="left", fill="x", expand=True, padx=(0, 10), ipady=5)
        tk.Button(top_row, text="Find Folder", bg="#444", fg="white", relief="flat", padx=15, 
                  command=lambda: self.game_dir.set(filedialog.askdirectory())).pack(side="right")

        # The mod selector and info split
        split_box = tk.Frame(self.main_view, bg=NIGHT_BG)
        split_box.pack(fill="both", expand=True)

