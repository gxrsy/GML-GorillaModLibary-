    def switch_view(self, t):
        if t == "Illegal":
            if not messagebox.askyesno("Wait!", "These mods get you banned in pubs. You sure?"):
                self.switch_view("Core"); return

        self.active_tab.set(t)
        for n, b in self.nav_btns.items():
            b.config(bg=SIDE_BAR if n != t else "#3e3e3e", fg=GRAY_T if n != t else "white")
        
        for w in self.list_area.winfo_children(): w.destroy()
        
        if t == "Presets":
            for p in my_presets:
                tk.Checkbutton(self.list_area, text=p, variable=self.pre_checks[p], bg="#2d2d2d", fg="white", selectcolor="#444", font=("Segoe UI", 10, "bold"), padx=20, command=lambda x=p: self.run_preset(x)).pack(anchor="w", pady=8)
        elif t == "Credits":
            txt = "GML - Gorilla Mod Library\n\nLead: Gxrsy\n\nBig thanks to the BepInEx guys, legoandmars, and Auros for the tools.\n\nKeep on monking!"
            tk.Label(self.list_area, text=txt, bg="#2d2d2d", fg="white", font=("Segoe UI", 10), justify="left", padx=20, pady=20).pack(anchor="nw")
            self.dev_label.config(text="By: Gxrsy")
        else:
            matches = [k for k, v in my_mod_list.items() if v["cat"] == t]
            for m in matches:
                tk.Checkbutton(self.list_area, text=m, variable=self.checks[m], bg="#2d2d2d", fg="white", selectcolor="#444", font=("Segoe UI", 10), padx=20, command=lambda x=m: self.show_info(x)).pack(anchor="w", pady=5)

    def run_preset(self, p):
        on = self.pre_checks[p].get()
        for m in my_presets[p]["items"]:
            if m in self.checks: self.checks[m].set(on)
        self.show_info(p, is_p=True)

    def show_info(self, n, is_p=False):
        data = my_presets[n] if is_p else my_mod_list[n]
        self.dev_label.config(text=f"Author: {data.get('dev', data.get('by'))}")
        self.info_text.config(text=data.get('info', data.get('about')))

    def wipe_all(self):
        p = self.game_dir.get()
        target = os.path.join(p, "BepInEx")
        if not os.path.exists(target):
            messagebox.showinfo("?", "Nothing to delete here.")
            return
        if messagebox.askyesno("Confirm", "Kill all mods?"):
            try:
                shutil.rmtree(target)
                for f in ["doorstop_config.ini", "winhttp.dll"]:
                    if os.path.exists(os.path.join(p, f)): os.remove(os.path.join(p, f))
                self.log_var.set("Cleaned.")
            except Exception as e: messagebox.showerror("Error", str(e))

    def do_install(self):
        root = self.game_dir.get()
        if not os.path.exists(os.path.join(root, "Gorilla Tag.exe")):
            messagebox.showerror("Oops", "Select the right GT folder first.")
            return
        
        self.run_btn.config(state="disabled", text="HUNTING...")
        errors = []; ctx = ssl._create_unverified_context()

        for name, var in self.checks.items():
            if var.get():
                self.log_var.set(f"Working on {name}...")
                self.win.update()
                try:
                    # check github api
                    link = f"https://api.github.com/repos/{my_mod_list[name]['github']}/releases"
                    r = urllib.request.Request(link, headers={'User-Agent': 'Mozilla/5.0'})
                    with urllib.request.urlopen(r, context=ctx) as resp:
                        js = json.loads(resp.read().decode())
                        files = js[0]['assets']
                        # find zip or dll
                        match = next((a for a in files if (a['name'].lower().endswith('.zip') or a['name'].lower().endswith('.dll')) 
                                       and (not my_mod_list[name].get('find') or my_mod_list[name]['find'] in a['name'].lower())), None)
                        
                        if match:
                            dl = match['browser_download_url']
                            fname = match['name']
                            with urllib.request.urlopen(urllib.request.Request(dl, headers={'User-Agent': 'Mozilla/5.0'}), context=ctx) as stream:
                                raw = stream.read()
                                if fname.lower().endswith('.zip'):
                                    with zipfile.ZipFile(io.BytesIO(raw)) as z: z.extractall(root)
                                else:
                                    # move dll to plugins
                                    plug_dir = os.path.join(root, "BepInEx", "plugins")
                                    os.makedirs(plug_dir, exist_ok=True)
                                    with open(os.path.join(plug_dir, fname), "wb") as f: f.write(raw)
                        else: errors.append(name)
                except Exception as err: errors.append(f"{name} ({err})")
        
        self.run_btn.config(state="normal", text="INSTALL SELECTED")
        self.log_var.set("Done.")
        if errors: messagebox.showwarning("Issues", f"Failed: {', '.join(errors)}")
        else: messagebox.showinfo("Nice", "Mods updated successfully.")

